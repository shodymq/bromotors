{
  "name": "bromotors11",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @bromotors/api\" \"npm run dev -w @bromotors/web\"",
    "build": "npm run build -w @bromotors/db && npm run build -w @bromotors/api && npm run build -w @bromotors/web",
    "lint": "npm run lint -w @bromotors/api && npm run lint -w @bromotors/web",
    "setup:local": "npm run db:generate && npm run db:migrate -- --name init && npm run db:seed",
    "db:generate": "npm run prisma:generate -w @bromotors/db",
    "db:migrate": "npm run prisma:migrate -w @bromotors/db --",
    "db:seed": "npm run seed -w @bromotors/db",
    "smoke:local": "npm run smoke -w @bromotors/db"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "overrides": {
    "multer": "2.1.1",
    "postcss": "8.5.13",
    "lodash": "4.18.1",
    "tar": "7.5.10"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4"
  }
}
